# Apache .htaccess Configuration for TechnoPlus
# This file enables clean URLs (URL rewriting) for the website

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /shop/

# Redirect www to non-www (optional, for consistency)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ http://%1/$1 [R=301,L]

# Prevent access to sensitive files
<FilesMatch "^(config\.php|connec\.php|include\.php|lien\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# URL Rewriting Rules
# ============================================

# Boutique/Shop - Category with subcategory and product
# Example: /boutique/category/subcategory/product/
RewriteRule ^boutique/([^/]+)/([^/]+)/([^/]+)/?$ produit.php?link=$3 [L,QSA]

# Boutique/Shop - Category with subcategory
# Example: /boutique/category/subcategory/
RewriteRule ^boutique/([^/]+)/([^/]+)/?$ categorie.php?link=$2 [L,QSA]

# Boutique/Shop - Main category
# Example: /boutique/category/
RewriteRule ^boutique/([^/]+)/?$ categorie.php?link=$1 [L,QSA]

# Boutique/Shop - Main page
# Example: /boutique/
RewriteRule ^boutique/?$ categorie.php [L,QSA]

# Applications page
# Example: /applications/
RewriteRule ^applications/?$ applications.php [L,QSA]

# Contact page
# Example: /contact/
RewriteRule ^contact/?$ contact.php [L,QSA]

# Inscription/Registration page
# Example: /inscription/
RewriteRule ^inscription/?$ inscription.php [L,QSA]

# Connexion/Login page
# Example: /connexion/
RewriteRule ^connexion/?$ connexion.php [L,QSA]

# Password forgotten page
# Example: /mdp-oublie/
RewriteRule ^mdp-oublie/?$ mdp-oublie.php [L,QSA]

# User account page
# Example: /compte/
RewriteRule ^compte/?$ compte.php [L,QSA]

# Logout page
# Example: /deconnexion/
RewriteRule ^deconnexion/?$ deconnexion.php [L,QSA]

# Order detail page
# Example: /commande/123/
RewriteRule ^commande/([0-9]+)/?$ detail_commande.php?cmdId=$1 [L,QSA]

# Express order page
# Example: /commande-express/
RewriteRule ^commande-express/?$ commande-express.php [L,QSA]

# Shopping cart page
# Example: /panier/
RewriteRule ^panier/?$ cart.php [L,QSA]

# Checkout page with optional order ID
# Example: /checkout/ or /checkout/123/
RewriteRule ^checkout/([0-9]+)/?$ checkout.php?cmdId=$1 [L,QSA]
RewriteRule ^checkout/?$ checkout.php [L,QSA]

# Order confirmation page
# Example: /confirm/ABC123/
RewriteRule ^confirm/([^/]+)/?$ confirm.php?cmd=$1 [L,QSA]

# Search page with optional search term
# Example: /recherche/ or /recherche/keyword/
RewriteRule ^recherche/([^/]+)/([^/]+)/?$ recherche.php?categorie=$1&marque=$2 [L,QSA]
RewriteRule ^recherche/([^/]+)/?$ recherche.php?search=$1 [L,QSA]
RewriteRule ^recherche/?$ recherche.php [L,QSA]

# Generic content pages
# Example: /about-us/ or any other page slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ contenu.php?link=$1 [L,QSA]

# ============================================
# Performance & Security Settings
# ============================================

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Disable directory browsing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# Custom error pages (optional)
# ErrorDocument 404 /shop/404.php
# ErrorDocument 500 /shop/500.php
